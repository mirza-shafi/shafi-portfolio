---
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/ThemeToggle.jsx';
import VisitorCounter from '../components/VisitorCounter.jsx';
import Carousel from '../components/Carousel.jsx';
import ContactForm from '../components/ContactForm.jsx';
import '../styles/global.css';

const techs = [
  { name: 'Python',      icon: 'https://cdn.simpleicons.org/python/3776AB' },
  { name: 'FastAPI',     icon: 'https://cdn.simpleicons.org/fastapi/009688' },
  { name: 'LangChain',   icon: 'https://cdn.simpleicons.org/langchain/1C3C3C' },
  { name: 'Docker',      icon: 'https://cdn.simpleicons.org/docker/2496ED' },
  { name: 'React',       icon: 'https://cdn.simpleicons.org/react/61DAFB' },
  { name: 'Node.js',     icon: 'https://cdn.simpleicons.org/nodedotjs/339933' },
  { name: 'PostgreSQL',  icon: 'https://cdn.simpleicons.org/postgresql/4169E1' },
  { name: 'MongoDB',     icon: 'https://cdn.simpleicons.org/mongodb/47A248' },
  { name: 'OpenAI',      icon: 'https://cdn.simpleicons.org/openai/74AA9C' },
  { name: 'HuggingFace', icon: 'https://cdn.simpleicons.org/huggingface/FFD21E' },
  { name: 'Ollama',      icon: 'https://cdn.simpleicons.org/ollama/ffffff' },
  { name: 'Streamlit',   icon: 'https://cdn.simpleicons.org/streamlit/FF4B4B' },
];
// Duplicate for seamless infinite marquee
const marqueeItems = [...techs, ...techs];
---

<Layout
  title="Shafi | AI Engineer"
  description="Mirza Shafi — Passionate AI Engineer & Full-Stack Developer building intelligent workflows, LLM integrations, and SaaS solutions."
>
  <div class="theme-wrapper" id="theme-wrapper">

    {/* ── NAVBAR ── */}
    <nav class="navbar">
      <div class="nav-container">
        <div class="nav-logo">
          <span class="font-bold">Shafi</span>
          <span class="text-muted hidden-mobile"> | AI Engineer</span>
        </div>
        <ul class="nav-links">
          <li><a href="#experience">Experience</a></li>
          <li><a href="#projects">Projects</a></li>
          <li><a href="#skills">Skills</a></li>
          <li><a href="#contact">Contact</a></li>
        </ul>
        <div class="nav-actions flex gap-4 items-center">
          <ThemeToggle client:load />
          <a href="#contact" class="btn-primary" style="padding: 8px 16px; border-radius: 30px;">
            Get In Touch
          </a>
        </div>
      </div>
    </nav>

    <main class="main-content">

      {/* ── HERO SECTION ── */}
      <section class="hero-section hidden-animate" id="home">
        <div class="hero-grid">
          <div class="hero-text">
            <h1 class="hero-title">Hello, <br /> I am Mirza Shafi</h1>
            <p class="hero-subtitle">
              Passionate AI Engineer &amp; Full-Stack Developer, building
              <span class="highlight-text">intelligent workflows</span>,
              <span class="highlight-text">LLM integrations</span>, and
              <span class="highlight-text">SaaS solutions</span>.
            </p>
            <div class="hero-buttons">
              <a href="/images/MIRZA%20MD%20SHAFI%20UDDIN_CV_AI_Engineer.pdf" target="_blank" rel="noreferrer" class="btn-outline">
                Download CV
              </a>
              <a href="#contact" class="btn-primary">Get In Touch</a>
              <VisitorCounter client:load />
            </div>
          </div>

          <div class="hero-image-wrapper">
            <img src="/images/shafi-formal.png" alt="Mirza Shafi" class="hero-image" />
            <div class="glow-effect behind-image"></div>
          </div>
        </div>

        {/* Marquee — pure CSS, no JS needed */}
        <div class="trusted-banner">
          <p class="text-center text-muted mb-4 font-mono text-sm">Empowering intelligent solutions with</p>
          <div class="marquee">
            <div class="marquee-content">
              {marqueeItems.map((tech, i) => (
                <span class="marquee-item" key={i}>
                  <img src={tech.icon} alt={tech.name} width="20" height="20" />
                  {tech.name}
                </span>
              ))}
            </div>
          </div>
        </div>
      </section>

      {/* ── EXPERIENCE SECTION ── */}
      <section class="section hidden-animate" id="experience">
        <div class="section-header text-center">
          <p class="badge font-mono text-accent">Career Path &amp; Skills</p>
          <h2 class="section-title">Expertise &amp; Experience</h2>
        </div>

        <div class="experience-layout">
          {/* Left: Expertise */}
          <div class="expertise-column">
            <h3 class="column-title">My Expertise</h3>
            <div class="expertise-list">

              <div class="expertise-item">
                <h4 class="expertise-title">AI Agents &amp; LLM Integrations</h4>
                <ul class="expertise-bullets">
                  <li>• Engineered stateful AI agents for workflow automation.</li>
                  <li>• Refined prompt architectures and conversational memory.</li>
                  <li>• Experience with Gemini, OpenAI, and LangChain frameworks.</li>
                </ul>
              </div>

              <div class="expertise-item">
                <h4 class="expertise-title">Backend &amp; API Development</h4>
                <ul class="expertise-bullets">
                  <li>• Developed scalable APIs and Webhooks using FastAPI and Node.js.</li>
                  <li>• Built robust backend systems for high-performance applications.</li>
                  <li>• Database design and optimization across PostgreSQL and NoSQL.</li>
                </ul>
              </div>

              <div class="expertise-item">
                <h4 class="expertise-title">Full-Stack Development</h4>
                <ul class="expertise-bullets">
                  <li>• Created intuitive and dynamic user interfaces using React.</li>
                  <li>• Seamlessly integrated frontend with backend and AI services.</li>
                  <li>• Maintained clean code standards and scalable architectures.</li>
                </ul>
              </div>

              <div class="expertise-item">
                <h4 class="expertise-title">Workflow &amp; Automation</h4>
                <ul class="expertise-bullets">
                  <li>• Designed automated solutions for complex technical workflows.</li>
                  <li>• Leveraged tool-calling and APIs to streamline operations.</li>
                  <li>• Tackled technical challenges with innovative software solutions.</li>
                </ul>
              </div>

            </div>
          </div>

          {/* Right: Timeline */}
          <div class="timeline-column">
            <h3 class="column-title">Professional Experience</h3>
            <div class="timeline-container">

              <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content card-glass">
                  <div class="flex-between flex-wrap gap-2">
                    <h3 class="job-title">AI Agent &amp; LLM Intern</h3>
                    <span class="job-date font-mono text-muted text-sm badge-small">Dec 2025 – Feb 2026</span>
                  </div>
                  <p class="company-text text-accent font-medium mb-3 mt-1">Mevrik</p>
                  <ul class="job-bullets">
                    <li>Engineered and deployed AI agents to automate CX workflows using stateful logic and tool-calling.</li>
                    <li>Refined prompt architectures and conversational memory, increasing model accuracy.</li>
                    <li>Integrated Gemini capabilities into a production SaaS environment using FastAPI and Webhooks.</li>
                  </ul>
                </div>
              </div>

              <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content card-glass">
                  <div class="flex-between flex-wrap gap-2">
                    <h3 class="job-title">Junior Engagement Officer</h3>
                    <span class="job-date font-mono text-muted text-sm badge-small">Jun 2024 – Oct 2024</span>
                  </div>
                  <p class="company-text text-accent font-medium mb-3 mt-1">X Integrated Marketing Agency</p>
                  <ul class="job-bullets">
                    <li>Assisted in planning and executing digital marketing campaigns to increase audience engagement.</li>
                    <li>Coordinated with creative and technical teams to ensure smooth campaign delivery and improved customer interactions.</li>
                  </ul>
                </div>
              </div>

              <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content card-glass">
                  <div class="flex-between flex-wrap gap-2">
                    <h3 class="job-title">Secretary (IT Department)</h3>
                    <span class="job-date font-mono text-muted text-sm badge-small">Feb 2024 – Jun 2025</span>
                  </div>
                  <p class="company-text text-accent font-medium mb-3 mt-1">Robotics Club of BRAC University</p>
                  <ul class="job-bullets">
                    <li>Managed IT operations and provided technical support for workshops, events, and robotics competitions.</li>
                    <li>Led digital initiatives and contributed to robotics projects, including an Arduino-based soccer robot.</li>
                  </ul>
                </div>
              </div>

            </div>
          </div>
        </div>
      </section>

      {/* ── PROJECTS SECTION ── */}
      <section class="section hidden-animate" id="projects">
        <div class="section-header text-center">
          <p class="badge font-mono text-accent">Real-world Solutions</p>
          <h2 class="section-title">Featured Projects</h2>
        </div>
        <Carousel client:visible />
      </section>

    </main>

    {/* ── CONTACT SECTION ── */}
    <section class="section hidden-animate" id="contact" style="padding-bottom: 0;">
      <div class="section-header text-center">
        <p class="badge font-mono text-accent">Contact Me</p>
        <h2 class="section-title">Let's Work Together on Your Next Project</h2>
        <p class="text-muted mx-auto max-w-lg mt-4">
          Have an idea you want to bring to life? I'm here to help you create something amazing. Get in touch and let's discuss how we can make your vision a reality.
        </p>
      </div>

      <div class="contact-layout">
        {/* Left: Direct Links */}
        <div class="contact-links-column">
          <h3 class="contact-column-title">Feel free to reach out directly...</h3>
          <div class="contact-cards">

            <a href="https://linkedin.com/in/mirza-shafi" target="_blank" rel="noreferrer" class="contact-card card-glass">
              <div class="contact-icon">
                <svg width="24" height="24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" viewBox="0 0 24 24">
                  <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
                  <rect x="2" y="9" width="4" height="12"></rect>
                  <circle cx="4" cy="4" r="2"></circle>
                </svg>
              </div>
              <div>
                <h4>LinkedIn</h4>
                <p>Connect with me on LinkedIn</p>
              </div>
            </a>

            <a href="https://github.com/mirza-shafi" target="_blank" rel="noreferrer" class="contact-card card-glass">
              <div class="contact-icon">
                <svg width="24" height="24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" viewBox="0 0 24 24">
                  <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
                </svg>
              </div>
              <div>
                <h4>GitHub</h4>
                <p>Check out my repositories</p>
              </div>
            </a>

            <a href="https://wa.me/8801938820835" target="_blank" rel="noreferrer" class="contact-card card-glass">
              <div class="contact-icon">
                <svg width="24" height="24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" viewBox="0 0 24 24">
                  <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
                </svg>
              </div>
              <div>
                <h4>WhatsApp</h4>
                <p>Chat with me on WhatsApp</p>
              </div>
            </a>

            <a href="https://mail.google.com/mail/?view=cm&to=mirza.md.shafi.uddin@gmail.com" target="_blank" rel="noreferrer" class="contact-card card-glass">
              <div class="contact-icon">
                <svg width="24" height="24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" viewBox="0 0 24 24">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                  <polyline points="22,6 12,13 2,6"></polyline>
                </svg>
              </div>
              <div>
                <h4>Email</h4>
                <p>mirza.md.shafi.uddin@gmail.com</p>
              </div>
            </a>

            <a href="/images/MIRZA%20MD%20SHAFI%20UDDIN_CV_AI_Engineer.pdf" target="_blank" class="contact-card card-glass">
              <div class="contact-icon">
                <svg width="24" height="24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" viewBox="0 0 24 24">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                  <polyline points="7 10 12 15 17 10"></polyline>
                  <line x1="12" y1="15" x2="12" y2="3"></line>
                </svg>
              </div>
              <div>
                <h4>Download CV</h4>
                <p>Get my latest resume as PDF</p>
              </div>
            </a>

            <div class="contact-info-card card-glass">
              <h4 class="mb-3 font-bold">Quick Response</h4>
              <p class="text-muted text-sm mb-4">
                I typically respond to messages within 24 hours. For urgent inquiries, feel free to reach out on WhatsApp for faster communication.
              </p>
              <p class="text-muted text-sm">
                Whether you're looking to collaborate on a project, need technical consultation, or just want to connect, I'm always open to meaningful conversations. Let's build something amazing together!
              </p>
            </div>

          </div>
        </div>

        {/* Right: Contact Form */}
        <div class="contact-form-column card-glass">
          <div class="form-header text-center">
            <div class="form-icon-circle mx-auto mb-4">
              <svg width="28" height="28" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" viewBox="0 0 24 24">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </svg>
            </div>
            <h3 class="mb-2 font-bold" style="font-size: 1.5rem;">Let's Build Something Smart</h3>
            <p class="text-muted text-sm">Tell me about your AI project idea and I'll get back to you within 24 hours.</p>
          </div>
          <ContactForm client:visible />
        </div>

      </div>
    </section>

    {/* ── FOOTER ── */}
    <footer class="footer-mini text-center text-muted border-t pt-6 pb-6 border-gray-800 text-sm mt-12">
      <p>© 2026 Mirza Shafi. All rights reserved.</p>
    </footer>

  </div>

  {/* Scroll animation observer — runs once on load */}
  <script>
    function initScrollAnimations() {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) entry.target.classList.add('show-animate');
          });
        },
        { threshold: 0.1 }
      );
      document.querySelectorAll('.hidden-animate').forEach(el => observer.observe(el));
    }
    // Run on first load
    initScrollAnimations();
    // Also run after any client-side navigation (Astro View Transitions)
    document.addEventListener('astro:page-load', initScrollAnimations);
  </script>
</Layout>
